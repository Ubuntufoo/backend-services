{
  "name": "@ebay-inventory/watcher-service",
  "version": "0.0.0",
  "description": "Config and path conventions for the watcher-service boundary.",
  "type": "module",
  "private": true,
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "exports": {
    ".": {
      "types": "./build/index.d.ts",
      "import": "./build/index.js"
    }
  },
  "scripts": {
    "build:deps": "pnpm --filter @ebay-inventory/types build && pnpm --filter @ebay-inventory/data build",
    "build": "pnpm run build:deps && tsc --build",
    "typecheck": "pnpm run build:deps && tsc --noEmit --pretty false -p tsconfig.json",
    "test": "pnpm run typecheck && vitest run",
    "check": "pnpm run typecheck && pnpm run test"
  },
  "dependencies": {
    "@ebay-inventory/data": "workspace:*",
    "@ebay-inventory/types": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "typescript": "^5.9.3",
    "vitest": "^4.0.8"
  }
}
