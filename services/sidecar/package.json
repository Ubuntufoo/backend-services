{
  "name": "sidecar",
  "version": "1.8.9",
  "description": "Model Context Protocol (MCP) sidecar server that exposes eBay's Sell APIs to local AI assistants with OAuth, Trading API, and HTTP transport support.",
  "type": "module",
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "private": true,
  "scripts": {
    "build:deps": "pnpm --filter @ebay-inventory/env build && pnpm --filter @ebay-inventory/types build && pnpm --filter @ebay-inventory/data build && pnpm --filter @ebay-inventory/image-service build",
    "build": "pnpm run build:deps && tsc --build && tsc-alias",
    "start": "node build/index.js",
    "dev": "pnpm run build:deps && tsx src/server-http.ts",
    "dev:stdio": "pnpm run build:deps && tsx src/index.ts",
    "ebay:diagnose-offer": "tsx src/scripts/diagnose-offer.ts",
    "ebay:diagnose-sandbox": "tsx src/scripts/diagnose-sandbox.ts",
    "ebay:diagnose-sandbox-config": "tsx src/scripts/diagnose-sandbox-config.ts",
    "ebay:opt-in-selling-policies": "tsx src/scripts/opt-in-selling-policies.ts",
    "ebay:reconcile-published-listing": "tsx src/scripts/reconcile-published-listing.ts",
    "ebay:setup-sandbox": "tsx src/scripts/setup-sandbox.ts",
    "lint": "eslint .",
    "validate:env": "tsx src/scripts/validate-env.ts",
    "ebay:validate-oauth": "tsx src/scripts/validate-ebay-oauth.ts",
    "test": "pnpm run build:deps && vitest run",
    "test:coverage": "pnpm run build:deps && vitest run --coverage",
    "setup": "tsx src/scripts/setup.ts",
    "sync": "tsx src/scripts/dev-sync.ts",
    "update:api-status": "tsx src/scripts/update-api-status-doc.ts",
    "diagnose": "tsx src/scripts/diagnostics.ts",
    "typecheck": "pnpm run build:deps && tsc --noEmit --pretty false -p tsconfig.json",
    "check": "pnpm run typecheck && pnpm run lint && prettier --check \"src/**/*.{ts,js,json,md}\" \"tests/**/*.ts\" \"README.md\"",
    "fix": "eslint . --fix && prettier --write \"src/**/*.{ts,js,json,md}\" \"tests/**/*.ts\" \"README.md\""
  },
  "keywords": [
    "mcp",
    "ebay",
    "ebay-api",
    "model-context-protocol",
    "ai-tools",
    "oauth",
    "trading-api"
  ],
  "author": "Yosef Hayim Sabag",
  "license": "MIT",
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@ebay-inventory/data": "workspace:*",
    "@ebay-inventory/env": "workspace:*",
    "@ebay-inventory/image-service": "workspace:*",
    "@ebay-inventory/types": "workspace:*",
    "@modelcontextprotocol/sdk": "1.27.1",
    "@supabase/supabase-js": "2.78.0",
    "axios": "^1.13.6",
    "chalk": "^5.6.2",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "dotenv-stringify": "^3.0.1",
    "express": "^5.1.0",
    "fast-xml-parser": "^5.3.4",
    "helmet": "^8.1.0",
    "jose": "^6.2.1",
    "jsonwebtoken": "^9.0.2",
    "prompts": "^2.4.2",
    "update-notifier": "^7.3.1",
    "winston": "^3.19.0",
    "zod": "^3.25.76",
    "zod-to-json-schema": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.5",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.3.3",
    "@types/prompts": "^2.4.9",
    "@types/supertest": "^7.2.0",
    "@types/update-notifier": "^6.0.8",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.8",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-vitest": "^0.5.4",
    "husky": "^9.1.7",
    "nock": "^14.0.11",
    "openapi-typescript": "^7.13.0",
    "prettier": "^3.8.1",
    "supertest": "^7.1.4",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.8"
  },
  "packageManager": "pnpm@10.14.0",
  "engines": {
    "node": ">=18.0.0"
  }
}
