{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "outDir": "./build",
    "rootDir": "./src",
    "baseUrl": "./",
    "paths": {
      "@/*": ["./src/*"]
    },
    "composite": true,
    "incremental": true,
    "tsBuildInfoFile": "./build/tsconfig.tsbuildinfo"
  },
  "include": ["src/**/*"],
  "exclude": [
    "node_modules",
    "build",
    "docs",
    "tests",
    "src/scripts/test-endpoints.ts",
    "eslint.config.js",
    "vitest.config.ts"
  ]
}
