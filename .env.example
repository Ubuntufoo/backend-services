MCP_PORT=3001
OAUTH_ENABLED=false
EBAY_ENABLED=false

# Supabase app: browser-safe values
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_placeholder_key
SUPABASE_PROJECT_REF=your-project-ref

# Supabase app: server-only secret
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Gemini app: server-only secret
GEMINI_API_KEY=your_gemini_api_key

# Optional Gemini model
# GEMINI_MODEL=gemini-3.1-flash-lite

# eBay sidecar: disabled for DB-only local development
# EBAY_ENVIRONMENT=sandbox
# EBAY_CLIENT_ID=your_ebay_client_id
# EBAY_CLIENT_SECRET=your_ebay_client_secret
# EBAY_REDIRECT_URI=https://localhost:3000/api/ebay/callback

# Cloudflare R2 storage configuration
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=your-r2-bucket-name
R2_S3_ENDPOINT=https://your_cloudflare_account_id.r2.cloudflarestorage.com

# Local development can use an r2.dev public host. Production should use your
# public bucket domain or custom image domain instead of hardcoding one in code.
R2_PUBLIC_BASE_URL=https://your-public-bucket-host.r2.dev
