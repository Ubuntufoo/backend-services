# MCP server port (example: 3001)
MCP_PORT=3001

# Enable OAuth authentication (true/false)
OAUTH_ENABLED=false

# Enable eBay integration (true/false)
EBAY_ENABLED=false

# Enable sidecar background job polling loop (true/false)
SIDECAR_JOB_RUNNER_ENABLED=true

# Public Supabase URL (browser-safe), e.g. https://<project>.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://fmiliwxthjonjwywuqta.supabase.co

# Supabase publishable (public) key for client-side usage
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_yGT1rmEqEUBzhUkVNHLyFA_ersE5b3G

# Supabase project reference (short project id)
SUPABASE_PROJECT_REF=fmiliwxthjonjwywuqta

# Supabase service role key (server-only secret, leave blank in examples)
SUPABASE_SERVICE_ROLE_KEY=

# Watcher-service local filesystem configuration
WATCHER_INCOMING_DIR=/Users/timothymurphy/image-incoming
# WATCHER_BASE_DIR=./watcher
# WATCHER_PROCESSED_DIR=./watcher/processed

# Gemini API key (server-only secret for text/image generation)
GEMINI_API_KEY=

# Optional Gemini model override (uncomment to set)
# GEMINI_MODEL=gemini-3.1-flash-lite

# eBay sidecar settings (uncomment and fill to enable eBay integration)
# EBAY_ENVIRONMENT=sandbox  # 'sandbox' or 'production'
# EBAY_CLIENT_ID=        # eBay OAuth client ID
# EBAY_CLIENT_SECRET=    # eBay OAuth client secret (server-only)
# EBAY_REDIRECT_URI=     # Redirect URI for OAuth flow

# ==============================================================================
# Cloudflare R2 Storage Configuration
# ==============================================================================
# Cloudflare R2: account identifier
R2_ACCOUNT_ID=1fc7c2ef63ec0078513d851464ec8fdf

# R2 S3-compatible API endpoint
R2_ENDPOINT=https://1fc7c2ef63ec0078513d851464ec8fdf.r2.cloudflarestorage.com

# R2 bucket/container name where files are stored
R2_BUCKET_NAME=mfh-image-hosting

# Public gateway base URL for read-only access (used for public assets)
R2_PUBLIC_BASE_URL=https://pub-e309aa00f17549eda19c5bb519e38059.r2.dev

# R2 access key ID (server-only) — leave empty in example
R2_ACCESS_KEY_ID=

# R2 secret access key (server-only) — leave empty in example
R2_SECRET_ACCESS_KEY=
