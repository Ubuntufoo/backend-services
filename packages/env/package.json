{
  "name": "@ebay-inventory/env",
  "version": "0.0.0",
  "description": "Shared explicit environment validation helpers for backend services.",
  "type": "module",
  "private": true,
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "exports": {
    ".": {
      "types": "./build/index.d.ts",
      "import": "./build/index.js"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "typecheck": "tsc --noEmit --pretty false -p tsconfig.test.json",
    "test": "vitest run",
    "check": "pnpm run typecheck && pnpm run test"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "typescript": "^5.9.3",
    "vitest": "^4.0.8"
  }
}
