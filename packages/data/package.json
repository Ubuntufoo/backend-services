{
  "name": "@ebay-inventory/data",
  "version": "0.0.0",
  "description": "Shared Supabase-backed data access for backend services.",
  "type": "module",
  "private": true,
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "exports": {
    ".": {
      "types": "./build/index.d.ts",
      "import": "./build/index.js"
    }
  },
  "scripts": {
    "build:deps": "pnpm --filter @ebay-inventory/env build && pnpm --filter @ebay-inventory/types build",
    "build": "pnpm run build:deps && tsc --build",
    "typecheck": "pnpm run build:deps && tsc --noEmit --pretty false -p tsconfig.test.json",
    "test": "pnpm run typecheck && vitest run",
    "check": "pnpm run test"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.967.0",
    "@ebay-inventory/env": "workspace:*",
    "@ebay-inventory/types": "workspace:*",
    "@supabase/supabase-js": "2.78.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "typescript": "^5.9.3",
    "vitest": "^4.0.8"
  }
}
