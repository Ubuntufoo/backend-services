{
  "name": "backend-services",
  "version": "1.8.9",
  "description": "Workspace orchestration for the eBay Inventory Manager backend services monorepo.",
  "type": "module",
  "private": true,
  "license": "MIT",
  "author": "Yosef Hayim Sabag",
  "repository": {
    "type": "git",
    "url": "https://github.com/Ubuntufoo/backend-services.git"
  },
  "homepage": "https://github.com/Ubuntufoo/backend-services#readme",
  "bugs": {
    "url": "https://github.com/Ubuntufoo/backend-services/issues"
  },
  "scripts": {
    "build": "pnpm -r --if-present build",
    "dev": "pnpm --filter sidecar dev",
    "dev:sidecar": "pnpm --filter sidecar dev",
    "dev:sidecar:stdio": "pnpm --filter sidecar dev:stdio",
    "ebay:diagnose-offer": "pnpm --filter sidecar ebay:diagnose-offer",
    "ebay:diagnose-condition-policy": "pnpm --filter sidecar ebay:diagnose-condition-policy",
    "ebay:diagnose-live-readiness": "pnpm --filter sidecar ebay:diagnose-live-readiness",
    "ebay:diagnose-sandbox": "pnpm --filter sidecar ebay:diagnose-sandbox",
    "ebay:diagnose-sandbox-config": "pnpm --filter sidecar ebay:diagnose-sandbox-config",
    "pricing:diagnose-apify-config": "pnpm --filter sidecar pricing:diagnose-apify-config",
    "pricing:price-one": "pnpm --filter sidecar pricing:price-one",
    "pricing:smoke-apify": "pnpm --filter sidecar pricing:smoke-apify",
    "ebay:cleanup-sandbox": "pnpm --filter sidecar ebay:cleanup-sandbox",
    "ebay:list-live-publish-config": "pnpm --filter sidecar ebay:list-live-publish-config",
    "ebay:opt-in-selling-policies": "pnpm --filter sidecar ebay:opt-in-selling-policies",
    "ebay:reconcile-published-listing": "pnpm --filter sidecar ebay:reconcile-published-listing",
    "ebay:setup-sandbox": "pnpm --filter sidecar ebay:setup-sandbox",
    "setup": "pnpm --filter sidecar setup",
    "validate:env": "pnpm --filter sidecar validate:env",
    "validate:ebay-oauth": "pnpm --filter sidecar ebay:validate-oauth",
    "sync": "pnpm --filter sidecar sync",
    "update:api-status": "pnpm --filter sidecar update:api-status",
    "diagnose": "pnpm --filter sidecar diagnose",
    "test": "pnpm -r --if-present test",
    "test:coverage": "pnpm -r --if-present test:coverage",
    "typecheck": "pnpm -r --if-present typecheck",
    "lint": "pnpm -r --if-present lint",
    "check:layout": "node ./scripts/verify-canonical-layout.mjs",
    "check": "pnpm run check:layout && pnpm -r --if-present check",
    "fix": "pnpm --filter sidecar fix",
    "format": "pnpm --filter sidecar fix",
    "prepare": "husky install"
  },
  "devDependencies": {
    "husky": "^9.1.7"
  },
  "packageManager": "pnpm@10.14.0",
  "engines": {
    "node": ">=18.0.0"
  }
}
