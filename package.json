{
  "name": "backend-services",
  "version": "1.8.9",
  "description": "Backend services for eBay Inventory Manager: sidecar, watcher, image processing, R2 storage, Gemini AI, eBay API, and job runner.",
  "type": "module",
  "private": true,
  "license": "MIT",
  "author": "Yosef Hayim Sabag",
  "repository": {
    "type": "git",
    "url": "https://github.com/Ubuntufoo/backend-services.git"
  },
  "homepage": "https://github.com/Ubuntufoo/backend-services#readme",
  "bugs": {
    "url": "https://github.com/Ubuntufoo/backend-services/issues"
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev:sidecar": "pnpm --filter sidecar dev",
    "dev": "pnpm -r dev",
    "test": "pnpm -r test",
    "test:coverage": "pnpm -r test:coverage",
    "typecheck": "pnpm -r typecheck",
    "check": "pnpm -r check",
    "fix": "pnpm -r fix",
    "lint": "eslint services/**/*.ts",
    "format": "prettier --write \"services/**/src/**/*.{ts,js,json,md}\"",
    "prepare": "husky install"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.6",
    "@vitest/ui": "^4.1.6",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vitest": "^0.5.4",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "vitest": "^4.1.6"
  },
  "packageManager": "pnpm@10.14.0",
  "engines": {
    "node": ">=18.0.0"
  }
}
