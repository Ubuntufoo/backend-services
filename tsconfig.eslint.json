{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true
  },
  "include": [
    "src/**/*",
    "tests/**/*",
    "services/**/src/**/*.ts",
    "services/**/src/**/*.d.ts",
    "services/**/tests/**/*.ts",
    "services/**/vitest.config.ts",
    "vitest.config.ts",
    "eslint.config.js"
  ],
  "exclude": ["node_modules", "build", "docs"]
}
