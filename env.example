# Optional local sidecar endpoint.
SIDECAR_API_URL=http://localhost:3001

# Supabase app: browser-safe values
NEXT_PUBLIC_SUPABASE_URL=https://fmiliwxthjonjwywuqta.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
# Legacy fallback if your project still uses anon keys instead of publishable keys.
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase app: server-only secret
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Gemini app: server-only secret
GEMINI_API_KEY=your-gemini-api-key
# Optional: defaults to gemini-3.1-flash-lite when unset.
# GEMINI_MODEL=gemini-3.1-flash-lite

# Supabase MCP: tooling-only values
# Gatekeeper admin access is seeded in public.gatekeeper_config, not via env vars.
SUPABASE_PROJECT_REF=fmiliwxthjonjwywuqta

# Watcher-service local filesystem configuration
WATCHER_INCOMING_DIR=/Users/timothymurphy/image-incoming
# WATCHER_BASE_DIR=./watcher
# WATCHER_PROCESSED_DIR=./watcher/processed

# eBay sidecar: set EBAY_ENABLED=false for DB-only local development.
# While false, the credential block below is ignored.
EBAY_ENABLED=false

# eBay sidecar: required app credentials only when EBAY_ENABLED=true
# EBAY_CLIENT_ID=your-client-id
# EBAY_CLIENT_SECRET=your-client-secret
# EBAY_REDIRECT_URI=your-redirect-uri
# EBAY_ENVIRONMENT=sandbox
# EBAY_REFRESH_TOKEN="your-refresh-token" # Preferred. Quote because refresh tokens contain #.
# EBAY_USER_REFRESH_TOKEN="your-refresh-token" # Compatibility fallback for older setup flows.
# EBAY_API_BASE_URL=https://api.sandbox.ebay.com
# EBAY_OAUTH_BASE_URL=https://api.sandbox.ebay.com/identity/v1/oauth2/token

# eBay sidecar: optional defaults
# EBAY_MARKETPLACE_ID=EBAY_US
# EBAY_CONTENT_LANGUAGE=en-US
# EBAY_PUBLISH_ENABLED=false

# eBay sidecar: user OAuth tokens
# Do not paste the callback URL code= value here.
# Do not paste API Explorer Authorization: Bearer access tokens here.
# Preferred for new setup flows:
# EBAY_REFRESH_TOKEN=your-refresh-token
# Legacy fallback:
# EBAY_USER_REFRESH_TOKEN=your-refresh-token
# EBAY_USER_ACCESS_TOKEN=generated-automatically
# EBAY_APP_ACCESS_TOKEN=generated-automatically

# eBay sidecar: logging
# EBAY_LOG_LEVEL=info
# EBAY_ENABLE_FILE_LOGGING=true

# Cloudflare R2 storage configuration
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=your-r2-bucket-name
R2_S3_ENDPOINT=https://your-cloudflare-account-id.r2.cloudflarestorage.com
R2_PUBLIC_BASE_URL=https://your-public-bucket-host.example.com
